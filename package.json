{
  "name": "api",
  "version": "2.0.0",
  "scripts": {
    "build": "npm run lint && tsc --project tsconfig.prod.json",
    "build:vercel": "esbuild src/app.ts --bundle --platform=node --target=node20 --outfile=api/index.js --packages=external --tsconfig=tsconfig.prod.json && cp openapi.yaml api/openapi.yaml",
    "clean-install": "rm -rf ./node_modules && rm -r package-lock.json && npm i",
    "dev": "node -r dotenv/config ./node_modules/.bin/ts-node ./src/main",
    "dev:watch": "nodemon --exec \"npm run dev\" --watch ./src --ext .ts",
    "supabase:start": "supabase start",
    "bootstrap": "supabase db reset && node scripts/bootstrap.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "node ./dist/main.js",
    "type-check": "tsc -b --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@sentry/node": "^10.43.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^10.3.0",
    "@swc/core": "^1.15.11",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.2.1",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^6.0.3",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.2",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supabase": "^2.76.16",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
