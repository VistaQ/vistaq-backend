{
  "name": "api",
  "version": "0.0.0",
  "scripts": {
    "build": "npm run lint && tsc --project tsconfig.prod.json",
    "clean-install": "rm -rf ./node_modules && rm -r package-lock.json && npm i",
    "dev": "node -r dotenv/config ./node_modules/.bin/ts-node ./src/main dotenv_config_path=./config/.env.development",
    "dev:watch": "nodemon --exec \"npm run dev\" --watch ./src --ext .ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "node ./dist/main.js",
    "type-check": "tsc -b --noEmit",
    "seed": "node scripts/seed-test-data.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:groups": "jest --testPathPattern=\"tests/groups\\.test\\.ts\" --runInBand",
    "test:events": "jest --testPathPattern=\"tests/events\\.test\\.ts\" --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@swc/core": "^1.15.11",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.2.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.2",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
